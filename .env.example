# ===========================================
# Database Configuration
# ===========================================
DATABASE_URL="postgresql://username:password@localhost:5432/upn_alumni_scraper?schema=public"

# ===========================================
# LinkedIn Authentication
# ===========================================
LINKEDIN_EMAIL="your-linkedin-email@example.com"
LINKEDIN_PASSWORD="your-linkedin-password"

# ===========================================
# Playwright Configuration
# ===========================================
PLAYWRIGHT_HEADLESS="true"
PLAYWRIGHT_BROWSER="chromium"

# ===========================================
# Scraping Configuration
# ===========================================
# Delay between requests (milliseconds)
SCRAPER_DELAY_MIN="2000"
SCRAPER_DELAY_MAX="5000"

# Retry configuration
MAX_RETRIES="3"
RETRY_BASE_DELAY="1000"

# Concurrent browsers limit (keep low to avoid detection)
CONCURRENT_BROWSERS_LIMIT="1"

# Daily quota to avoid ban
DAILY_PROFILE_QUOTA="200"
HOURLY_PROFILE_QUOTA="50"

# ===========================================
# Output Configuration
# ===========================================
OUTPUT_DIR="./data/exports"
LOG_LEVEL="info"

# ===========================================
# Advanced Stealth Configuration
# ===========================================
# Set to true for extra stealth measures (slower but safer)
ENABLE_EXTRA_STEALTH="true"

# User agent rotation (comma-separated list)
USER_AGENTS=""

# ===========================================
# Session Management
# ===========================================
# Session validity in hours
SESSION_MAX_AGE="24"
